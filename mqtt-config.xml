<?xml version="1.0" encoding="UTF-8" ?>
<config>
    <enterprise>
        <enabled>false</enabled>
    </enterprise>
    <mqtt>
        <listeners>
            <tcp>
                <port>1883</port>
                <bind-address>0.0.0.0</bind-address>
            </tcp>
        </listeners>
        <security>
            <default-permission-level>ALL</default-permission-level>
        </security>
    </mqtt>
    <restrictions>
        <max-client-id-length>65536</max-client-id-length>
        <max-connections>10000</max-connections>
        <max-keep-alive>60</max-keep-alive>
    </restrictions>
    <persistence>
        <enabled>true</enabled>
        <store-queue-messages-while-disconnected>true</store-queue-messages-while-disconnected>
        <max-retained-messages>1000</max-retained-messages>
    </persistence>
</config>
