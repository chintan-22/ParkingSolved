# Environment Configuration Template

# Database Configuration
DATABASE_URL=postgresql://parking_user:parking_pass@localhost:5432/parking_db
SQLALCHEMY_ECHO=False

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=parking_user
MQTT_PASSWORD=parking_pass
MQTT_TOPICS=parking/lot/+/ultrasonic,parking/lot/+/lpr_entry,parking/lot/+/lpr_exit,parking/lot/+/occupancy_estimate

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
API_WORKERS=4

# Frontend Configuration
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000

# Google Places API (Optional)
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY_HERE

# Twilio Configuration (Optional - for SMS alerts)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Features
ENABLE_SIMULATION=True
ENABLE_MQTT_INGESTION=True
ENABLE_ADMIN_DASHBOARD=True

# Monitoring
SENTRY_DSN=optional_sentry_dns_url
